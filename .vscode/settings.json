{
	"deno.enable": true,
	"deno.lint": true,
	"editor.defaultFormatter": "denoland.vscode-deno",
	"editor.formatOnSave": true,
	"[javascript]": {
		"editor.defaultFormatter": "denoland.vscode-deno"
	},
	"[json]": {
		"editor.quickSuggestions": {
			"strings": true
		},
		"editor.suggest.insertMode": "replace",
		"editor.defaultFormatter": "denoland.vscode-deno"
	},
	"[typescript]": {
		"editor.defaultFormatter": "denoland.vscode-deno"
	},
	"[typescriptreact]": {
		"editor.defaultFormatter": "denoland.vscode-deno"
	},
}